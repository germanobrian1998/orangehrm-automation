{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "paths": {
      "@qa-framework/core": ["packages/core/src"],
      "@qa-framework/shared-utils": ["packages/shared-utils/src"],
      "@config/*": ["src/config/*"],
      "@utils/*": ["src/utils/*"],
      "@types/*": ["src/types/*"]
    }
  },
  "include": ["src", "tests"],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "./packages/core" },
    { "path": "./packages/shared-utils" },
    { "path": "./packages/orangehrm-suite" },
    { "path": "./packages/hrm-api-suite" },
    { "path": "./packages/orangehrm-api-suite" }
  ]
}
