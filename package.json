{
  "name": "orangehrm-automation",
  "version": "1.0.0",
  "description": "QA Automation monorepo - scalable, reusable framework for OrangeHRM using Playwright",
  "author": "germanobrian1998",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "playwright test",
    "test:dev": "ENVIRONMENT=development playwright test",
    "test:staging": "ENVIRONMENT=staging playwright test",
    "test:prod": "ENVIRONMENT=production playwright test --grep @smoke",
    "test:ci": "ENVIRONMENT=ci playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:smoke:dev": "ENVIRONMENT=development playwright test --grep @smoke",
    "test:smoke:staging": "ENVIRONMENT=staging playwright test --grep @smoke",
    "test:smoke:prod": "ENVIRONMENT=production playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:regression:dev": "ENVIRONMENT=development playwright test --grep @regression",
    "test:regression:staging": "ENVIRONMENT=staging playwright test --grep @regression",
    "test:regression:prod": "ENVIRONMENT=production playwright test --grep @regression",
    "test:api:staging": "ENVIRONMENT=staging playwright test --grep @api",
    "test:api:prod": "ENVIRONMENT=production playwright test --grep @api",
    "test:watch": "playwright test --watch",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:specific": "playwright test",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "build": "tsc && npm run build --workspaces --if-present",
    "build:packages": "npm run build --workspaces --if-present",
    "clean": "rm -rf dist test-results blob-report playwright-report && npm run clean --workspaces --if-present",
    "report": "playwright show-report",
    "test:core": "npm run test --workspace=packages/core",
    "test:orangehrm": "npm run test --workspace=packages/orangehrm-suite",
    "test:hrm-api": "npm run test --workspace=packages/hrm-api-suite",
    "test:orangehrm-api": "npm run test --workspace=packages/orangehrm-api-suite",
    "test:shared-utils": "npm run test --workspace=packages/shared-utils",
    "test:all-packages": "npm run test --workspaces --if-present",
    "test:mock": "USE_MOCK_API=true playwright test --grep @mock",
    "test:mock:api": "USE_MOCK_API=true playwright test --grep @mock",
    "load:smoke": "k6 run tests/performance/smoke-load.js",
    "load:soak": "k6 run tests/performance/soak-test.js",
    "load:spike": "k6 run tests/performance/spike-test.js",
    "load:stress": "k6 run tests/performance/stress-test.js",
    "load:all": "npm run load:smoke && npm run load:soak && npm run load:spike && npm run load:stress",
    "load:smoke:staging": "BASE_URL=https://staging.example.com k6 run tests/performance/smoke-load.js",
    "load:results": "open ./k6-results.html",
    "test:report": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "test:report:serve": "allure serve allure-results",
    "test:report:history": "cp -r allure-report/history allure-results/history 2>/dev/null || true && allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "api-docs:validate": "npx swagger-cli validate docs/openapi.yml",
    "api-docs:preview": "npx swagger-ui-watcher docs/openapi.yml --port 8888",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@faker-js/faker": "^8.0.0",
    "@playwright/test": "^1.40.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.6.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.1.2",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.1",
    "msw": "^2.12.14",
    "prettier": "^3.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  }
}
