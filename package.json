{
  "name": "orangehrm-automation",
  "version": "1.0.0",
  "description": "QA Automation monorepo - scalable, reusable framework for OrangeHRM using Playwright",
  "author": "germanobrian1998",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:watch": "playwright test --watch",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:specific": "playwright test",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "build": "tsc && npm run build --workspaces --if-present",
    "build:packages": "npm run build --workspaces --if-present",
    "clean": "rm -rf dist test-results blob-report playwright-report && npm run clean --workspaces --if-present",
    "report": "playwright show-report",
    "test:core": "npm run test --workspace=packages/core",
    "test:orangehrm": "npm run test --workspace=packages/orangehrm-suite",
    "test:hrm-api": "npm run test --workspace=packages/hrm-api-suite",
    "test:shared-utils": "npm run test --workspace=packages/shared-utils",
    "test:all-packages": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.0.0",
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "allure-playwright": "^3.6.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  }
}
