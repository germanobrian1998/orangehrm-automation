.env
.env.local
.env.*.local

# Test Results
test-results/
blob-report/
playwright-report/
allure-results/
allure-report/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Build
dist/
out/
site/
tests/**/*.js
tests/**/*.js.map
tests/**/*.d.ts
tests/**/*.d.ts.map

# k6 performance test scripts are intentionally plain JS — keep them tracked
!tests/performance/smoke-load.js
!tests/performance/soak-test.js
!tests/performance/spike-test.js
!tests/performance/stress-test.js
!tests/performance/lib/*.js

# Logs
logs/
*.log
npm-debug.log*

