{
  "env": {
    "node": true,
    "es2020": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    "playwright-report",
    "test-results",
    "playwright.config.ts"
  ],
  "rules": {
    "no-unused-vars": "off"
  }
}