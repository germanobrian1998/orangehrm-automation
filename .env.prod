# Production Environment (example)
ENVIRONMENT=production
ORANGEHRM_BASE_URL=https://prod-api.example.com
ORANGEHRM_ADMIN_USERNAME=admin
ORANGEHRM_ADMIN_PASSWORD=${PROD_PASSWORD}
TEST_TIMEOUT=45000
API_TIMEOUT=15000
BROWSER=chromium
HEADLESS=true
LOG_LEVEL=warn
DEBUG=false
ALLURE_RESULTS_DIR=./test-results/prod
