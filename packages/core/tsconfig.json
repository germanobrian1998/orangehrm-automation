{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "composite": true,
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@core/*": ["src/*"],
      "@core/page-objects": ["src/page-objects/base.page"],
      "@core/api-client": ["src/api-client/base.api-client"],
      "@core/logger": ["src/logger/logger"],
      "@core/config": ["src/config/Config"],
      "@core/utils": ["src/utils/TestHelpers"],
      "@core/fixtures": ["src/fixtures/TestFixtures"],
      "@core/types": ["src/types/index"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
