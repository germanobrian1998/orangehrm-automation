    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@playwright/test": "^1.40.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@qa-framework/core": "*",
    "@qa-framework/shared-utils": "*",
    "@faker-js/faker": "^8.0.0"
  }
}
