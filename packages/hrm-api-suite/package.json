{
  "name": "@qa-framework/hrm-api-suite",
  "version": "1.0.0",
  "description": "HRM REST API test suite - request/response validation, contract testing, performance",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
